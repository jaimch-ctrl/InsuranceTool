<script>
// ── State ──────────────────────────────────────────────
let imgs = {A:null,B:null,C:null};
let chartPV=null, chartWD=null;

// ── Upload ─────────────────────────────────────────────
function handleUpload(p,inp){
  const file=inp.files[0]; if(!file) return;
  const zone=document.getElementById('zone-'+p);
  const reader=new FileReader();
  reader.onload=e=>{
    imgs[p]=e.target.result;
    zone.className='uzone has';
    zone.querySelector('.uzone-label').textContent=`保單 ${p} ✓ 已選取`;
    zone.querySelector('.uzone-sub').textContent=file.name;
    let pv=zone.querySelector('.uzone-prev');
    if(!pv){pv=document.createElement('img');pv.className='uzone-prev';zone.appendChild(pv);}
    pv.src=e.target.result;
    document.getElementById('btn-ai').disabled=false;
  };
  reader.readAsDataURL(file);
}

// ── AI Extract ─────────────────────────────────────────
async function extractAll(){
  const btn=document.getElementById('btn-ai');
  const st=document.getElementById('ai-status');
  btn.disabled=true;
  st.className='ai-status';
  st.textContent='🤖 AI 分析中，請稍候…';

  const results={};
  for(const p of ['A','B','C']){
    if(!imgs[p]) continue;
    const zone=document.getElementById('zone-'+p);
    zone.className='uzone loading';
    zone.querySelector('.uzone-label').textContent=`保單 ${p} 分析中…`;
    try{
      const d=await callClaude(p,imgs[p]);
      results[p]=d;
      zone.className='uzone done';
      zone.querySelector('.uzone-label').textContent=`保單 ${p} ✅ 完成`;
    }catch(e){
      zone.className='uzone err';
      zone.querySelector('.uzone-label').textContent=`保單 ${p} ❌ 失敗`;
      console.error(p,e);
    }
  }

  fillFields(results);
  btn.disabled=false;
  const done=Object.keys(results);
  if(done.length){
    st.className='ai-status ok';
    st.textContent=`✅ 保單 ${done.join('、')} 已自動填入（黃色欄位）。請確認數字後按「重新試算」。`;
  } else {
    st.className='ai-status err';
    st.textContent='❌ 無法讀取資料。可能原因：圖片模糊、數字被遮擋、或網路問題。請手動輸入數字。';
  }
}

// ── Claude API ─────────────────────────────────────────
async function callClaude(policyLabel, dataUrl){
  const b64=dataUrl.split(',')[1];
  const mime=(dataUrl.match(/data:([^;]+);/)||[])[1]||'image/jpeg';

  const prompt=`你是保單資料擷取專家。分析這張保單試算表圖片（保單${policyLabel}），擷取以下資料，只回傳純JSON，不含說明或markdown。

需要擷取的欄位：
{
  "policy_no": "保單號碼",
  "company": "保險公司",
  "premium_paid": 已繳總保費(數字USD),
  "rate_assumed": 試算宣告利率(數字%),
  "sv_by_year": [
    {"year":1, "sv_base":保單價值準備金, "sv_surrender":解約金, "interest_share":增值回饋分享金或假設紅利解約金},
    ...盡量多年...
  ]
}

注意：
- sv_surrender = 解約金(B欄) 或 解約金/祝壽保險金
- interest_share = 增值回饋分享金 或 假設紅利解約金(D欄)
- 如欄位看不清填null
- 只回傳JSON，不加任何文字`;

  const resp=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:2000,
      messages:[{
        role:'user',
        content:[
          {type:'image',source:{type:'base64',media_type:mime,data:b64}},
          {type:'text',text:prompt}
        ]
      }]
    })
  });

  if(!resp.ok){
    const errText=await resp.text();
    throw new Error(`API ${resp.status}: ${errText}`);
  }

  const apiData=await resp.json();

  // Robust response parsing — handle text blocks AND tool_use blocks
  let text='';
  if(apiData.content && Array.isArray(apiData.content)){
    for(const block of apiData.content){
      if(block.type==='text') text+=block.text;
      // If tool_use block somehow appears, try to get input
      if(block.type==='tool_use' && block.input) text+=JSON.stringify(block.input);
    }
  }

  // Extract JSON from response (handle markdown fences if present)
  text=text.trim();
  const jsonMatch=text.match(/\{[\s\S]*\}/);
  if(!jsonMatch) throw new Error('回應中找不到 JSON 格式資料');
  return JSON.parse(jsonMatch[0]);
}

// ── Fill Fields ────────────────────────────────────────
function fillFields(results){
  function set(id,val){
    if(val==null||isNaN(val)) return;
    const el=document.getElementById(id);
    if(!el) return;
    el.value=parseFloat(val.toFixed(2));
    el.classList.add('ai-filled');
  }

  if(results.A){
    const d=results.A;
    if(d.sv_by_year&&d.sv_by_year.length){
      // Pick year 2 (policy A is at yr2)
      const yr2=d.sv_by_year.find(r=>r.year===2)||d.sv_by_year[1]||d.sv_by_year[0];
      if(yr2) set('a_sv', yr2.sv_surrender||yr2.sv_base);
    }
    if(d.rate_assumed) set('a_rate',d.rate_assumed);
  }

  if(results.B){
    const d=results.B;
    if(d.sv_by_year&&d.sv_by_year.length){
      const yr1=d.sv_by_year[0];
      if(yr1) set('b_sv', yr1.sv_surrender||yr1.sv_base);
    }
    if(d.rate_assumed) set('b_rate',d.rate_assumed);
  }

  if(results.C){
    const d=results.C;
    if(d.sv_by_year){
      const yr4=d.sv_by_year.find(r=>r.year===4);
      const yr5=d.sv_by_year.find(r=>r.year===5);
      const yr6=d.sv_by_year.find(r=>r.year===6);
      if(yr4) set('c_sv0', yr4.sv_surrender||yr4.sv_base);
      if(yr5) set('c_sv5', yr5.sv_surrender||yr5.sv_base);
      if(yr6) set('c_sv6', yr6.sv_surrender||yr6.sv_base);
    }
  }

  setTimeout(()=>recalc(),200);
}

// ── C schedule helper ──────────────────────────────────
function getCsv(i, C_SV0, C_SV5, C_SV6, C_RATE){
  // i=0 → 115年 → C policy yr4
  if(i===0) return C_SV0;
  if(i===1) return C_SV5;
  if(i===2) return C_SV6;
  return C_SV6*Math.pow(1+C_RATE,i-2);
}

// ── Main Simulation ────────────────────────────────────
function recalc(){
  // Read globals
  const FX      = +document.getElementById('p_fx').value||31;
  const TARGET  = (+document.getElementById('p_target').value||120000)/FX;
  const YEARS   = +document.getElementById('p_years').value||12;
  const AGE0    = +document.getElementById('p_age').value||74;

  // Policy params
  const A_SV    = +document.getElementById('a_sv').value||16482;
  const A_RATE  = (+document.getElementById('a_rate').value||4.2)/100;
  const A_FLOOR = +document.getElementById('a_floor').value||0;
  const A_CAP   = +document.getElementById('a_cap').value||0;
  const A_MODE  = document.getElementById('a_mode').value;
  const A_SYR   = +document.getElementById('a_start_yr').value||1;
  const A_EYR   = +document.getElementById('a_end_yr').value||0;

  const B_SV    = +document.getElementById('b_sv').value||15635;
  const B_RATE  = (+document.getElementById('b_rate').value||4.2)/100;
  const B_FLOOR = +document.getElementById('b_floor').value||0;
  const B_CAP   = +document.getElementById('b_cap').value||0;
  const B_MODE  = document.getElementById('b_mode').value;
  const B_SYR   = +document.getElementById('b_start_yr').value||1;
  const B_EYR   = +document.getElementById('b_end_yr').value||0;

  const C_SV0   = +document.getElementById('c_sv0').value||27445;
  const C_SV5   = +document.getElementById('c_sv5').value||31103;
  const C_SV6   = +document.getElementById('c_sv6').value||39400;
  const C_RATE  = (+document.getElementById('c_rate').value||2.6)/100;
  const C_MODE  = document.getElementById('c_mode').value;
  const C_SYR   = +document.getElementById('c_start_yr').value||3;
  const C_EYR   = +document.getElementById('c_end_yr').value||0;

  // Simulate
  let A_sv=A_SV, B_sv=B_SV;
  let A_capUsed=0, B_capUsed=0;
  const rows=[];

  for(let i=0;i<YEARS;i++){
    const simYr   = i+1;          // 1-based simulation year
    const calYr   = 115+i;
    const calAD   = 2026+i;
    const age     = AGE0+i;

    const A_start = A_sv;
    const B_start = B_sv;
    const C_cur   = getCsv(i,C_SV0,C_SV5,C_SV6,C_RATE);
    const C_prev  = i===0 ? C_SV0*0.87 : getCsv(i-1,C_SV0,C_SV5,C_SV6,C_RATE);
    const C_inc   = Math.max(0,C_cur-C_prev);

    const A_int   = A_start*A_RATE;
    const B_int   = B_start*B_RATE;

    // Is each policy active this year?
    const A_active = (simYr>=A_SYR) && (A_EYR===0||simYr<=A_EYR);
    const B_active = (simYr>=B_SYR) && (B_EYR===0||simYr<=B_EYR);
    const C_active = (simYr>=C_SYR) && (C_EYR===0||simYr<=C_EYR);

    let needed=TARGET;
    let wA=0, wB=0, wC=0;

    // ── Withdraw from A ──
    if(A_active){
      const avail_pr = Math.max(0, A_start - A_FLOOR);
      const cap_left = A_CAP>0 ? Math.max(0,A_CAP-A_capUsed) : Infinity;

      if(A_MODE==='int_only'){
        const take=Math.min(A_int,needed); wA=take; needed-=take;
      } else if(A_MODE==='int_then_principal'){
        const takeI=Math.min(A_int,needed); needed-=takeI;
        const takeP=Math.min(Math.min(avail_pr,cap_left),needed); needed-=takeP;
        wA=takeI+takeP;
        A_capUsed+=takeP;
      } else { // principal_first
        const takeP=Math.min(Math.min(avail_pr,cap_left),needed); needed-=takeP;
        wA=takeP; A_capUsed+=takeP;
      }
    }

    // ── Withdraw from B ──
    if(B_active){
      const avail_pr=Math.max(0,B_start-B_FLOOR);
      const cap_left=B_CAP>0?Math.max(0,B_CAP-B_capUsed):Infinity;

      if(B_MODE==='int_only'){
        const take=Math.min(B_int,needed); wB=take; needed-=take;
      } else if(B_MODE==='int_then_principal'){
        const takeI=Math.min(B_int,needed); needed-=takeI;
        const takeP=Math.min(Math.min(avail_pr,cap_left),needed); needed-=takeP;
        wB=takeI+takeP; B_capUsed+=takeP;
      } else {
        const takeP=Math.min(Math.min(avail_pr,cap_left),needed); needed-=takeP;
        wB=takeP; B_capUsed+=takeP;
      }
    }

    // ── Withdraw from C ──
    if(C_active){
      if(C_MODE==='int_only'){
        const take=Math.min(C_inc,needed); wC=take; needed-=take;
      } else if(C_MODE==='int_then_principal'){
        const takeI=Math.min(C_inc,needed); needed-=takeI;
        const takeP=Math.min(Math.max(0,C_cur-C_inc),needed); needed-=takeP;
        wC=takeI+takeP;
      } else {
        const take=Math.min(C_cur,needed); wC=take; needed-=take;
      }
    }

    const A_end=Math.max(0,A_start-(wA-Math.min(wA,A_int)));
    const B_end=Math.max(0,B_start-(wB-Math.min(wB,B_int)));
    const totalWD   = wA+wB+wC;
    const totalTWD  = Math.round(totalWD*FX);
    const totalInt  = A_int+B_int+C_inc;
    const totalSV   = A_end+B_end+C_cur;
    const shortfall = needed>0.5?needed:0;

    let tag='', rowClass='';
    if(calAD===2026) tag='✓ 保單B已回本';
    if(calAD===2028){ tag='★ 保單C回本！'; rowClass='milestone'; }
    if(A_end<200&&A_start>200) rowClass='danger';

    rows.push({
      calYr,calAD,age,simYr,
      A_start,A_int,wA,A_end,A_active,
      B_start,B_int,wB,B_end,B_active,
      C_cur,C_inc,wC,C_active,
      totalSV,totalInt,totalWD,totalTWD,
      tag,rowClass,shortfall,
      C_note: !C_active ? '未啟動' : (i<2?'增值中':(i===2?'★回本':'供現金'))
    });

    A_sv=A_end; B_sv=B_end;
  }

  renderTable(rows);
  renderCharts(rows);
}

// ── Render Table ───────────────────────────────────────
function renderTable(rows){
  const tbody=document.getElementById('tbody');
  tbody.innerHTML='';
  rows.forEach(r=>{
    const tr=document.createElement('tr');
    if(r.rowClass) tr.className=r.rowClass;
    const twdCls=r.totalTWD>=115000?'twd-ok':(r.totalTWD>=90000?'twd-ne':'twd-sh');
    const fmtWd=v=>v>0?'－'+Math.round(v).toLocaleString():'—';
    const dim=v=>v?'':' style="opacity:.3"';
    tr.innerHTML=`
      <td class="yr-cell">${r.calYr}年<br>
        <span style="font-size:10px;color:var(--muted)">${r.calAD} ${r.age}歲</span>
        ${r.tag?`<br><span style="font-size:9px;color:var(--gold);font-weight:900">${r.tag}</span>`:''}
        ${r.shortfall>0.5?`<br><span style="font-size:9px;color:var(--red)">缺 ${Math.round(r.shortfall*31).toLocaleString()}</span>`:''}
      </td>
      <td class="A"${dim(r.A_active)}>${Math.round(r.A_start).toLocaleString()}</td>
      <td class="ic"${dim(r.A_active)}>＋${Math.round(r.A_int).toLocaleString()}</td>
      <td class="wd">${fmtWd(r.wA)}</td>
      <td class="A"${dim(r.A_active)}>${Math.round(r.A_end).toLocaleString()}</td>
      <td class="B"${dim(r.B_active)}>${Math.round(r.B_start).toLocaleString()}</td>
      <td class="ic"${dim(r.B_active)}>＋${Math.round(r.B_int).toLocaleString()}</td>
      <td class="wd">${fmtWd(r.wB)}</td>
      <td class="B"${dim(r.B_active)}>${Math.round(r.B_end).toLocaleString()}</td>
      <td class="C"${dim(r.C_active)}>${Math.round(r.C_cur).toLocaleString()}</td>
      <td class="wd">${fmtWd(r.wC)}</td>
      <td class="nc">${r.C_note}</td>
      <td class="sv-t">${Math.round(r.totalSV).toLocaleString()}</td>
      <td class="ic">＋${Math.round(r.totalInt).toLocaleString()}</td>
      <td class="wd">${Math.round(r.totalWD).toLocaleString()}</td>
      <td class="${twdCls}">${r.totalTWD.toLocaleString()}</td>
    `;
    tbody.appendChild(tr);
  });

  const sumWD=rows.reduce((s,r)=>s+r.totalWD,0);
  const last=rows[rows.length-1];
  const trG=document.createElement('tr'); trG.className='grand';
  trG.innerHTML=`
    <td colspan="12" style="text-align:right;font-family:'Noto Sans TC',sans-serif;font-size:10.5px;letter-spacing:.06em">${rows.length} 年累計</td>
    <td>${Math.round(last.totalSV).toLocaleString()}</td><td></td>
    <td>${Math.round(sumWD).toLocaleString()}</td>
    <td>${Math.round(sumWD*31).toLocaleString()}</td>
  `;
  tbody.appendChild(trG);
}

// ── Render Charts ──────────────────────────────────────
function renderCharts(rows){
  const labels=rows.map(r=>`${r.calYr}`);
  const font={family:"'Noto Sans TC',sans-serif",size:11,weight:'700'};
  const grid='rgba(0,0,0,0.07)';
  const baseO=t=>({
    responsive:true,interaction:{mode:'index',intersect:false},
    plugins:{legend:{labels:{font,color:'#1a1a1a',padding:10,usePointStyle:true}}},
    scales:{
      y:{title:{display:true,text:t,color:'#7a7060',font:{size:10,weight:'700'}},ticks:{color:'#3a3630',font},grid:{color:grid}},
      x:{ticks:{color:'#1a1a1a',font:{...font,size:10}},grid:{display:false}}
    }
  });
  if(chartPV) chartPV.destroy();
  if(chartWD) chartWD.destroy();

  chartPV=new Chart(document.getElementById('chartPV'),{type:'line',data:{labels,datasets:[
    {label:'保單A',data:rows.map(r=>Math.round(r.A_end)),borderColor:'#0a5c4a',backgroundColor:'rgba(10,92,74,.1)',tension:.3,pointRadius:4,borderWidth:2.5,fill:true},
    {label:'保單B',data:rows.map(r=>Math.round(r.B_end)),borderColor:'#0f3d7a',backgroundColor:'rgba(15,61,122,.07)',tension:.3,pointRadius:4,borderWidth:2.5,fill:true},
    {label:'保單C',data:rows.map(r=>Math.round(r.C_cur)),borderColor:'#6e3f00',backgroundColor:'rgba(110,63,0,.07)',tension:.3,pointRadius:4,borderWidth:2.5,fill:true},
  ]},options:baseO('解約金 / 餘額 USD')});

  const sO={...baseO('TWD')};
  sO.scales={...sO.scales,y:{...sO.scales.y,stacked:true}};
  chartWD=new Chart(document.getElementById('chartWD'),{type:'bar',data:{labels,datasets:[
    {label:'A 領回',data:rows.map(r=>Math.round(r.wA*31)),backgroundColor:'rgba(10,92,74,.55)',borderColor:'#0a5c4a',borderWidth:1.5,borderRadius:3,stack:'s'},
    {label:'B 領回',data:rows.map(r=>Math.round(r.wB*31)),backgroundColor:'rgba(15,61,122,.55)',borderColor:'#0f3d7a',borderWidth:1.5,borderRadius:3,stack:'s'},
    {label:'C 領回',data:rows.map(r=>Math.round(r.wC*31)),backgroundColor:'rgba(110,63,0,.55)',borderColor:'#6e3f00',borderWidth:1.5,borderRadius:3,stack:'s'},
    {label:'目標 120,000',data:rows.map(()=>120000),type:'line',borderColor:'#b83030',borderDash:[6,4],pointRadius:0,borderWidth:2,fill:false},
  ]},options:sO});
}

// ── Reset ──────────────────────────────────────────────
function resetAll(){
  const defs={
    p_fx:31,p_target:120000,p_years:12,p_age:74,
    a_sv:16482,a_rate:4.20,a_floor:0,a_cap:0,
    a_start_yr:1,a_end_yr:0,
    b_sv:15635,b_rate:4.20,b_floor:0,b_cap:0,
    b_start_yr:1,b_end_yr:0,
    c_sv0:27445,c_sv5:31103,c_sv6:39400,c_rate:2.60,
    c_start_yr:3,c_end_yr:0
  };
  Object.entries(defs).forEach(([k,v])=>{
    const el=document.getElementById(k);
    if(el){el.value=v;el.classList.remove('ai-filled');}
  });
  document.getElementById('a_mode').value='int_then_principal';
  document.getElementById('b_mode').value='int_only';
  document.getElementById('c_mode').value='int_then_principal';
  recalc();
}

// ── Init ───────────────────────────────────────────────
recalc();
</script>
